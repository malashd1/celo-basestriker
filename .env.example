VITE_REGISTRY_ADDR_TEST=
VITE_PAYMENT_ADDR_TEST=
VITE_REWARDS_ADDR_TEST=
VITE_TREASURY_ADDR_TEST=
VITE_BACKEND_URL_TEST=http://localhost:8787

# Base mainnet
VITE_BASE_RPC=https://mainnet.base.org
VITE_STRK_ADDR=
VITE_SHIP_ADDR=
VITE_EQUIP_ADDR=
VITE_REGISTRY_ADDR=
VITE_PAYMENT_ADDR=
VITE_REWARDS_ADDR=
