# Celo BaseStriker build defaults — picked up at vite build time.
# The runtime layer (src/web3/config.ts:detectDefaultNetwork) ALSO returns
# `celo` whenever window.location.hostname starts with `celo.`, so the
# same dist/ can serve celo.basestriker.xyz even if this file says `base`.
# Set here too so a fresh `npm run build` clone defaults to Celo without
# any extra env shim.
VITE_DEFAULT_NETWORK=celo
VITE_CELO_RPC=https://forno.celo.org
VITE_BACKEND_URL=https://api.basestriker.xyz
VITE_BACKEND_URL_TEST=https://api.basestriker.xyz
