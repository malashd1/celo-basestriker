{
  "name": "celo-basestriker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Celo-mainnet release of BaseStriker \u2014 Galaxian-style arcade shooter with cUSD shop, built for MiniPay",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "gen:levels": "tsx scripts/generate-levels.ts",
    "gen:icons": "node scripts/generate-icons.mjs",
    "prebuild": "node scripts/generate-icons.mjs || echo 'icons skipped (sharp not installed)'"
  },
  "dependencies": {
    "@coinbase/wallet-sdk": "^4.2.0",
    "@rainbow-me/rainbowkit": "^2.2.0",
    "@tanstack/react-query": "^5.62.0",
    "@wagmi/core": "^2.15.0",
    "@walletconnect/ethereum-provider": "^2.23.9",
    "viem": "^2.21.0",
    "wagmi": "^2.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "sharp": "^0.33.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}