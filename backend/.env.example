# ─── Required for production (NODE_ENV=production) ──────────────────
# Backend refuses to boot if any of these are missing or use dev defaults.

NODE_ENV=development
PORT=8787

# Base mainnet = 8453, Base Sepolia = 84532
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org

# EIP-712 signing key for score/mission/tournament claims.
# In production: provision a dedicated EOA, store the key in your secret manager
# (AWS KMS, GCP Secret Manager, HashiCorp Vault). The address must be authorised
# at RewardsDistributor.setSigner(...) and GameRegistry.setSigner(...).
# For local dev `backend/src/env.ts` falls back to a well-known public
# Hardhat/Anvil test key (mnemonic: "test test test test test test test test
# test test test junk", account index 1). Do NOT use that on mainnet.
SIGNER_KEY=

# Relayer EOA for fiat-onramp mints (Stripe → relayerMintShip/Equipment).
# Authorised at PaymentRouter.setRelayer(...). May share with SIGNER_KEY in dev.
RELAYER_KEY=

# Deployed contract addresses (required in production).
REWARDS_CONTRACT=0x0000000000000000000000000000000000000000
REGISTRY_CONTRACT=0x0000000000000000000000000000000000000000
PAYMENT_ROUTER=0x0000000000000000000000000000000000000000

# Comma-separated allowlist of origins permitted to call the API.
# Leave empty in development to reflect any origin. REQUIRED in production.
# Example: https://basestriker.xyz,https://www.basestriker.xyz
CORS_ALLOWLIST=

# Requests per IP per minute. Default 30.
RATE_LIMIT_RPS=30

# SQLite database path. Use an absolute path on a persistent volume in production.
DB_PATH=basestriker.db


# ─── Optional integrations ───────────────────────────────────────────

# Stripe fiat onramp. Leave blank to disable the /api/stripe/* endpoints.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Social linking (Discord + X/Twitter OAuth2). Leave blank to disable.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Public URLs used in OAuth redirects + Stripe checkout success/cancel.
# Must be reachable from the user's browser.
PUBLIC_BACKEND_URL=http://localhost:8787
PUBLIC_APP_URL=http://localhost:5173
